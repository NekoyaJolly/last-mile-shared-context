{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "forceConsistentCasingInFileNames": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@last-mile-context/schema": ["packages/schema/src/index.ts"],
      "@last-mile-context/schema/*": ["packages/schema/src/*"],
      "@last-mile-context/core": ["packages/core/src/index.ts"],
      "@last-mile-context/core/*": ["packages/core/src/*"],
      "@last-mile-context/cdp-collector": ["packages/cdp-collector/src/index.ts"],
      "@last-mile-context/cdp-collector/*": ["packages/cdp-collector/src/*"],
      "@last-mile-context/app-bridge": ["packages/app-bridge/src/index.ts"],
      "@last-mile-context/app-bridge/*": ["packages/app-bridge/src/*"],
      "@last-mile-context/react-bridge": ["packages/react-bridge/src/index.ts"],
      "@last-mile-context/react-bridge/*": ["packages/react-bridge/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "coverage", ".vitest"]
}
