{
  "name": "@last-mile-context/cdp-collector",
  "version": "0.1.0",
  "description": "Chrome DevTools Protocol collector that produces a Last-Mile Bundle (page / console / network / screenshot / debug context)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@last-mile-context/core": "workspace:*",
    "@last-mile-context/schema": "workspace:*",
    "@types/chrome-remote-interface": "^0.34.0",
    "chrome-remote-interface": "^0.34.0",
    "devtools-protocol": "^0.0.1173815"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
